# Startup Radar Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE (PostgreSQL via Supabase or Local)
# ============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/startup_radar

# ============================================================================
# API KEYS (Get from respective services)
# ============================================================================

# Tavily Search API
# Sign up: https://tavily.com (Free tier available)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API
# Sign up: https://console.anthropic.com
# Free tier: $5/month in credits
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Resend Email Service
# Sign up: https://resend.com (Free tier available)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
FROM_EMAIL=noreply@startup-radar.com
TO_EMAILS=your-email@example.com,another-email@example.com

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=8000

# ============================================================================
# SCHEDULER CONFIGURATION
# ============================================================================
# Run pipeline every N hours (default: 6)
SCHEDULE_INTERVAL_HOURS=6

# Enable/disable automatic pipeline execution
ENABLE_SCHEDULER=true

# ============================================================================
# OPTIONAL: SUPABASE (if using instead of local PostgreSQL)
# ============================================================================
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key
